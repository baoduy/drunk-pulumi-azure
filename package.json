{
  "name": "@drunk-pulumi/azure",
  "version": "0.0.1",
  "author": "drunkcoding@outlook.com",
  "description": "The custom helpers pulumi-azure",
  "license": "MIT",
  "private": false,
  "keywords": [
    "pulumi-azure"
  ],
  "pulumi": {
    "resource": false,
    "name": "@drunk-pulumi/azure"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/baoduy/drunk-pulumi-azure.git"
  },
  "scripts": {
    "fastBuild": "cross-env NODE_ENV=production && npx tsc",
    "build": "pnpm run update-tsconfig && pnpm run fastBuild && pnpm run copy-pkg",
    "ciBuild": "pnpm run fastBuild",
    "copy-pkg": "tsx ./.tasks/npm-package.ts && cpy README.md .out-bin/",
    "update-tsconfig": "tsx ./.tasks/update-tsconfig.ts",
    "pack": "cd .out-bin && pnpm pack && cd ../",
    "new-stack": "pulumi stack init --secrets-provider=passphrase",
    "up": "pulumi up --yes --skip-preview",
    "reup": "pulumi up --refresh --yes --skip-preview",
    "destroy": "pulumi destroy --yes --skip-preview",
    "update": "npx npm-check-updates -u && pnpm install",
    "export": "pulumi stack export --file state.json",
    "import": "pulumi stack import --file state.json",
    "test-leak": "cross-env PULUMI_DEBUG_PROMISE_LEAKS=true NODE_OPTIONS='--import tsx' TSX_TSCONFIG_PATH='./tsconfig.test.json' mocha --timeout 10000 'src/z_tests/**/*.ts'",
    "test": "cross-env NODE_OPTIONS='--import tsx' TSX_TSCONFIG_PATH='./tsconfig.test.json' mocha --timeout 10000 'src/z_tests/**/*.test.ts'",
    "testcert": "cross-env NODE_OPTIONS='--import tsx' TSX_TSCONFIG_PATH='./tsconfig.test.json' mocha --timeout 10000 '**/*.ts'",
    "test-cover": "cross-env NODE_OPTIONS='--import tsx' TSX_TSCONFIG_PATH='./tsconfig.test.json' nyc mocha --timeout 10000 'src/z_tests/**/*.ts'"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/netmask": "^2.0.6",
    "@types/node": "^26.1.1",
    "@types/node-forge": "^1.3.14",
    "cpy-cli": "^7.0.0",
    "cross-env": "^10.1.0",
    "mocha": "^11.7.6",
    "nyc": "^18.0.0",
    "replace-in-file": "8.4.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "@azure/keyvault-certificates": "^4.10.3",
    "@azure/keyvault-secrets": "^4.11.2",
    "@drunk-pulumi/azure-providers": "^1.0.16",
    "@pulumi/azure-native": "^3.21.0",
    "@pulumi/azuread": "6.10.0",
    "@pulumi/pulumi": "^3.253.0",
    "@pulumi/random": "^4.21.0",
    "@pulumi/tls": "^5.5.0",
    "lodash": "^4.18.1",
    "netmask": "^2.1.1",
    "node-forge": "^1.4.0",
    "to-words": "^5.6.1"
  },
  "prettier": {
    "singleQuote": true
  }
}